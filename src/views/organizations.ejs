<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our partner organizations:</p>

        <div class="card-grid">
            <% organizations.forEach(org=> { %>
                <div class="card">
                    <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo">
                    <strong>
                        <%= org.name %>
                    </strong>
                    <p>
                        <%= org.description %>
                    </p>
                    <span>
                        <%= org.contact_email %>
                    </span>
                </div>
                <% }) %>
        </div>
    </main>

    <%- include('partials/footer') %>